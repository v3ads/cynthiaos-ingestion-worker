# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
SERVICE_NAME=cynthiaos-ingestion-worker
NODE_ENV=development

# ── Database (Neon Postgres) ──────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── AppFolio webhook authentication ──────────────────────────────────────────
APPFOLIO_HMAC_SECRET=replace_with_real_secret
